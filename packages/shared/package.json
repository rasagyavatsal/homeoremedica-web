{
  "name": "@homeoremedica/shared",
  "version": "2.6.0",
  "private": true,
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./data/*": "./data/*"
  },
  "scripts": {
    "build": "tsc",
    "postinstall": "tsc",
    "typecheck": "tsc --noEmit",
